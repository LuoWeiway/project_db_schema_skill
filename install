#!/bin/bash
# db-schema skill 一键安装脚本
# 使用方法: curl -sSL https://raw.githubusercontent.com/LuoWeiway/project_db_schema_skill/main/install | bash
# 或者: wget -qO- https://raw.githubusercontent.com/LuoWeiway/project_db_schema_skill/main/install | bash

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 打印函数
info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

# 检测操作系统
detect_os() {
    case "$(uname -s)" in
        Darwin*) echo "macos" ;;
        Linux*)  echo "linux" ;;
        CYGWIN*|MINGW*|MSYS*)  echo "windows" ;;
        *)       echo "unknown" ;;
    esac
}

# 获取 Claude skills 目录
get_skills_dir() {
    local os=$(detect_os)
    if [ "$os" = "windows" ]; then
        echo "$USERPROFILE/.claude/skills/db-schema"
    else
        echo "$HOME/.claude/skills/db-schema"
    fi
}

# 主安装流程
main() {
    echo ""
    echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     db-schema Skill 安装程序 v1.0.0        ║${NC}"
    echo -e "${BLUE}║     Database Schema Management Tool        ║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"
    echo ""

    # 检查依赖
    info "检查依赖..."

    if ! command -v python3 &> /dev/null && ! command -v python &> /dev/null; then
        error "未找到 Python，请先安装 Python 3.x"
    fi

    PYTHON_CMD=$(command -v python3 || command -v python)
    info "Python: $($PYTHON_CMD --version 2>&1 || echo 'unknown')"

    # 检查 pip
    if ! $PYTHON_CMD -m pip --version &> /dev/null; then
        error "未找到 pip，请先安装 pip"
    fi

    # 安装 PyMySQL
    info "安装 PyMySQL..."
    $PYTHON_CMD -m pip install pymysql -q 2>/dev/null || {
        warn "自动安装 PyMySQL 失败，请手动运行: pip install pymysql"
    }
    success "PyMySQL 已安装"

    # 创建目录
    SKILLS_DIR=$(get_skills_dir)
    info "安装目录: $SKILLS_DIR"

    mkdir -p "$SKILLS_DIR"

    # 下载 skill.md
    info "下载 skill.md..."
    REPO_URL="https://raw.githubusercontent.com/LuoWeiway/project_db_schema_skill/main"

    if command -v curl &> /dev/null; then
        curl -sSL "$REPO_URL/skill.md" -o "$SKILLS_DIR/skill.md"
    elif command -v wget &> /dev/null; then
        wget -q "$REPO_URL/skill.md" -O "$SKILLS_DIR/skill.md"
    else
        error "需要 curl 或 wget 来下载文件"
    fi

    success "skill.md 已安装"

    # 显示后续步骤
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║           安装成功！                       ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}后续步骤:${NC}"
    echo ""
    echo "1. 在项目中创建目录:"
    echo "   mkdir -p .claude/db-schema/scripts"
    echo ""
    echo "2. 下载脚本文件:"
    echo "   curl -sSL $REPO_URL/scripts/db_schema.py -o .claude/db-schema/scripts/db_schema.py"
    echo "   curl -sSL $REPO_URL/scripts/search_schema.py -o .claude/db-schema/scripts/search_schema.py"
    echo "   curl -sSL $REPO_URL/scripts/analyze_relations.py -o .claude/db-schema/scripts/analyze_relations.py"
    echo "   curl -sSL $REPO_URL/scripts/validate_sql.py -o .claude/db-schema/scripts/validate_sql.py"
    echo "   curl -sSL $REPO_URL/scripts/update_schema.py -o .claude/db-schema/scripts/update_schema.py"
    echo ""
    echo "3. 初始化数据库配置:"
    echo "   python .claude/db-schema/scripts/db_schema.py init"
    echo ""
    echo "4. 读取表结构:"
    echo "   python .claude/db-schema/scripts/db_schema.py read-all"
    echo ""
    echo "5. 添加到 .gitignore:"
    echo "   echo '.claude/db-schema/config.json' >> .gitignore"
    echo ""
    echo -e "${BLUE}现在可以在 Claude Code 中使用 /db-schema 命令了！${NC}"
    echo ""
}

# 运行安装
main "$@"